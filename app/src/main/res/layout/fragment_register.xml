<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@drawable/registerbg">

    <ImageView
        android:id="@+id/imageViewLogo"
        android:layout_width="150dp"
        android:layout_height="80dp"
        android:layout_marginTop="30dp"
        android:scaleType="centerInside"
        android:src="@drawable/borrowlablogotext"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textViewRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/montserrat_black"
        android:text="@string/account_registration"
        android:lineSpacingMultiplier="0.8"
        android:textAlignment="center"
        android:textColor="@color/header"
        android:textSize="45sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imageViewLogo" />

    <EditText
        android:id="@+id/etRegisterName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/name"
        android:textSize="17sp"
        android:fontFamily="@font/montserrat_reg"
        android:minHeight="48dp"
        android:padding="14dp"
        android:textColor="#000000"
        android:textColorHint="@color/hint"
        android:background="@drawable/inputfield"
        app:layout_constraintTop_toBottomOf="@id/textViewRegister"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/etProgramYearSec"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etRegisterName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Spinner
            android:id="@+id/spinnerRegisterProgram"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:background="@drawable/inputfield"
            android:minHeight="48dp"
            android:padding="14dp"
            android:fontFamily="@font/montserrat_reg"
            android:spinnerMode="dropdown"
            android:textColorHint="@color/hint"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/etRegisterYearSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0"
            app:layout_constraintWidth_percent="0.48" />

        <EditText
            android:id="@+id/etRegisterYearSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:hint="@string/year_and_section"
            android:minHeight="48dp"
            android:padding="14dp"
            android:textColor="#000000"
            android:textColorHint="@color/hint"
            android:textSize="17sp"
            android:fontFamily="@font/montserrat_reg"
            android:background="@drawable/inputfield"
            app:layout_constraintStart_toEndOf="@id/spinnerRegisterProgram"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintWidth_percent="0.48" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <EditText
        android:id="@+id/etRegisterStudentNo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Student No (e.g. TUPC-12-3456)"
        android:maxLength="13"
        android:inputType="number"
        android:minHeight="48dp"
        android:padding="14dp"
        android:textColor="#000000"
        android:textColorHint="@color/hint"
        android:textSize="17sp"
        android:fontFamily="@font/montserrat_reg"
        android:background="@drawable/inputfield"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etProgramYearSec"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <EditText
        android:id="@+id/etRegisterEmail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Email"
        android:minHeight="48dp"
        android:padding="14dp"
        android:textColor="#000000"
        android:textColorHint="@color/hint"
        android:textSize="17sp"
        android:fontFamily="@font/montserrat_reg"
        android:background="@drawable/inputfield"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etRegisterStudentNo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- PASSWORD FIELD -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutPassword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/etRegisterEmail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/password_register"
            android:inputType="textPassword"
            android:minHeight="48dp"
            android:paddingEnd="50dp"
            android:padding="14dp"
            android:textColor="#000000"
            android:textColorHint="@color/hint"
            android:textSize="17sp"
            android:fontFamily="@font/montserrat_reg"
            android:background="@drawable/inputfield"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivToggleRPassword"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/show"
            android:contentDescription="@string/show_password"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/etPassword"
            app:layout_constraintBottom_toBottomOf="@id/etPassword"
            tools:ignore="TouchTargetSizeCheck" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONFIRM PASSWORD FIELD -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutConfirmPassword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="@string/confirm_password_register"
            android:inputType="textPassword"
            android:minHeight="48dp"
            android:paddingEnd="50dp"
            android:padding="14dp"
            android:textColor="#000000"
            android:textColorHint="@color/hint"
            android:textSize="17sp"
            android:fontFamily="@font/montserrat_reg"
            android:background="@drawable/inputfield"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivToggleCPassword"
            android:layout_width="40dp"
            android:layout_height="48dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/show"
            android:contentDescription="@string/show_password"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/etConfirmPassword"
            app:layout_constraintBottom_toBottomOf="@id/etConfirmPassword"
            tools:ignore="TouchTargetSizeCheck" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- REGISTER BUTTON -->
    <Button
        android:id="@+id/btnRegister"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/register_button"
        android:layout_marginTop="8dp"
        android:textSize="20sp"
        android:textColor="#FBFBFB"
        android:fontFamily="@font/montserrat_semibold"
        android:backgroundTint="@color/logregbtn"
        app:layout_constraintTop_toBottomOf="@id/layoutConfirmPassword"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvGoToLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/montserrat_medium"
        android:text="@string/go_to_login_page"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textStyle="italic"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/btnRegister"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
